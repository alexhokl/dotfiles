{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "qwen3.6:27b-mlx": {
          "name": "qwen3.6:27b"
        },
        "gemma4:26b-mlx": {
          "name": "gemma4:26b"
        },
        "glm-5.2:cloud": {
          "name": "glm-5.2"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    },
    "litert-lm": {
      "name": "Litert LM",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:9379/v1"
      },
      "models": {
        "gemma4-12b,gpu,1000000": {
          "name": "gemma4-12b"
        }
      }
    },
    "mlx": {
      "name": "MLX",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "default_model": {
          "name": "gemma-4-26B-A4B-it-OptiQ-4bit"
        }
      }
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "go-ali-expense-tracker create *": "deny",
          "go-ali-expense-tracker update *": "deny",
          "go-ali-expense-tracker delete *": "deny",
          "go-ali-expense-tracker copy *": "deny"
        }
      }
    }
  }
}
