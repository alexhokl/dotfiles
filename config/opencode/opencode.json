{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "devstral-small-2:24b": {
          "name": "devstral-small-2:24b [Ollama]"
        },
        "gpt-oss:20b": {
          "name": "gpt-oss:20b [Ollama]"
        },
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b [Ollama]"
        },
        "gemma4:26b": {
          "name": "gemma4:26b [Ollama]"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    },
    "litert-lm": {
      "name": "Litert LM",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:9379/v1"
      },
      "models": {
        "gemma4-12b,gpu,1000000": {
          "name": "gemma4-12b [Litert LM]"
        }
      }
    },
    "mlx": {
      "name": "MLX",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8080/v1"
      },
      "models": {
        "default_model": {
          "name": "gemma-4-26B-A4B-it-OptiQ-4bit [MLX]"
        }
      }
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "go-ali-expense-tracker create *": "deny",
          "go-ali-expense-tracker update *": "deny",
          "go-ali-expense-tracker delete *": "deny",
          "go-ali-expense-tracker copy *": "deny"
        }
      }
    }
  }
}
