{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "ollama": {
      "models": {
        "devstral-small-2:24b": {
          "name": "devstral-small-2:24b [Ollama]"
        },
        "gpt-oss:20b": {
          "name": "gpt-oss:20b [Ollama]"
        },
        "qwen3-coder:30b": {
          "name": "qwen3-coder:30b [Ollama]"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      }
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "bash": {
          "go-ali-expense-tracker create *": "deny",
          "go-ali-expense-tracker update *": "deny",
          "go-ali-expense-tracker delete *": "deny",
          "go-ali-expense-tracker copy *": "deny"
        }
      }
    }
  }
}
