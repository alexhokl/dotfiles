#!/bin/bash

# Updates a field on an existing JIRA issue interactively.
# Usage: jira_update
# Dependencies: jira-cli, gum, awk, $EDITOR (or vi as fallback)
# Description: Prompts the user to select an open issue (excluding closed,
#              rejected, and resolved), then select which field to update:
#              - description: Opens $EDITOR pre-populated with the current description
#              - parent:      Assigns a parent epic (excluding closed epics)
#              - feature:     Selects a feature from available custom field values
#              - sprint:      Selects a scrum board and active/future sprint, or moves to backlog
function jira_update() {
  if [ -z "$(which jira-cli)" ]; then
    echo "jira-cli has not been installed"
    return 1
  fi

  if [ -z "$(which gum)" ]; then
    echo "gum has not been installed"
    return 1
  fi

  if [ -z "$(which awk)" ]; then
    echo "awk has not been installed"
    return 1
  fi

  local jira_id update_field

  # Select the issue to update (GSC project only, exclude closed, rejected, resolved)
  jira_id=$(jira-cli list issues --project GSC --jql "project = GSC AND statusCategory != Done AND status NOT IN (Closed, Rejected, Resolved)" | gum filter --limit 1 --placeholder "Select issue to update..." | awk '{print $1}')
  if [ -z "$jira_id" ]; then
    echo "No issue selected."
    return 1
  fi

  # Select which field to update
  update_field=$(gum choose "description" "parent" "feature" "sprint")
  if [ -z "$update_field" ]; then
    echo "No field selected."
    return 1
  fi

  case "$update_field" in
    description)
      local description_file
      description_file=$(mktemp /tmp/jira_description_XXXXXX.md)

      echo "Fetching existing description..."
      jira-cli get issue --id "$jira_id" --description-only > "$description_file"

      echo "Opening editor for issue description (save and quit when done)..."
      ${EDITOR:-vi} "$description_file"

      if [ ! -s "$description_file" ]; then
        echo "No description provided."
        rm "$description_file"
        return 1
      fi

      echo jira-cli update issue --id "$jira_id" --description-file "$description_file"
      jira-cli update issue --id "$jira_id" --description-file "$description_file"

      rm "$description_file"
      ;;

    parent)
      local selected_parent_id
      selected_parent_id=$(jira-cli list issues --project GSC --type Epic --jql "project = GSC AND issuetype = Epic AND status NOT IN (Closed)" | gum filter --limit 1 --placeholder "Select parent epic..." | awk '{print $1}')
      if [ -z "$selected_parent_id" ]; then
        echo "No parent epic selected."
        return 1
      fi

      echo jira-cli update issue --id "$jira_id" --parent "$selected_parent_id"
      jira-cli update issue --id "$jira_id" --parent "$selected_parent_id"
      ;;

    feature)
      local selected_feature
      selected_feature=$(jira-cli list custom-field-values --name Feature | gum filter --limit 1 | awk '{print $2}')
      if [ -z "$selected_feature" ]; then
        echo "No feature selected."
        return 1
      fi

      echo jira-cli update issue --id "$jira_id" --custom-field "Feature=$selected_feature"
      jira-cli update issue --id "$jira_id" --custom-field "Feature=$selected_feature"
      ;;

    sprint)
      local selected_board sprint_choice selected_sprint
      selected_board=$(jira-cli list boards --type scrum | gum filter --limit 1 | awk '{print $1}')
      if [ -z "$selected_board" ]; then
        echo "No board selected."
        return 1
      fi

      sprint_choice=$(jira-cli list sprints --board-id "$selected_board" --state active --state future | gum filter --limit 1 --header "Select a sprint, or press Escape and choose backlog" | awk '{print $1}')
      if [ -z "$sprint_choice" ]; then
        sprint_choice=$(gum choose "backlog" --header "No sprint selected. Move to backlog instead?")
        if [ -z "$sprint_choice" ]; then
          echo "No sprint or backlog selected."
          return 1
        fi
      fi

      if [ "$sprint_choice" = "backlog" ]; then
        echo jira-cli update issue --id "$jira_id" --sprint none
        jira-cli update issue --id "$jira_id" --sprint none
      else
        selected_sprint="$sprint_choice"
        echo jira-cli update issue --id "$jira_id" --sprint "$selected_sprint"
        jira-cli update issue --id "$jira_id" --sprint "$selected_sprint"
      fi
      ;;
  esac
}


# Creates a new JIRA issue with interactive prompts.
# Usage: jira_create
# Dependencies: jira-cli, gum, awk, $EDITOR (or vi as fallback)
# Description: Guides the user through creating a JIRA issue by prompting for:
#              - Issue type: story, bug, or task
#              - Summary (required): Brief description of the issue
#              - Description (optional): Opens $EDITOR for markdown description input
#              - Project: JIRA project to create the issue in
#              - Client: Customer/client associated with the issue
#              - GCP Logging link (optional, bug only): Link to relevant GCP logs
#              - Project Team: Team responsible for the issue
#              - Feature: Feature area for the issue
#              - Board and Sprint: Assigns the issue to a sprint on a scrum board, or adds to backlog
function jira_create() {
  if [ -z "$(which jira-cli)" ]; then
    echo "jira-cli has not been installed"
    return 1
  fi

  if [ -z "$(which gum)" ]; then
    echo "gum has not been installed"
    return 1
  fi

  if [ -z "$(which awk)" ]; then
    echo "awk has not been installed"
    return 1
  fi

  local issue_type summary description_file project client logging_link project_team feature selected_board_id selected_sprint

  # Select issue type
  issue_type=$(gum choose "story" "bug" "task")
  if [ -z "$issue_type" ]; then
    echo "No issue type selected."
    return 1
  fi

  # Get summary from user
  summary=$(gum input --placeholder "Enter ${issue_type} summary...")
  if [ -z "$summary" ]; then
    echo "No summary provided."
    return 1
  fi

  # Create a temporary file for the description and open it in the default editor
  sanitized_summary=$(echo "$summary" | tr -s '[:space:][:punct:]' '_' | tr -d '[:cntrl:]' | tr '[:upper:]' '[:lower:]')
  description_file="/tmp/${sanitized_summary}.md"
  # if description_file does not exist, create it
  if [ ! -f "$description_file" ]; then
    description_file=$(mktemp "${description_file}")
  fi
  echo "Opening editor for ${issue_type} description (save and quit when done)..."
  ${EDITOR:-vi} "$description_file"

  # Check if the description file is empty and clear it if so
  if [ ! -s "$description_file" ]; then
    description_file=""
  fi

  # Select project
  project=$(jira-cli list projects | gum filter --limit 1 | awk '{print $1}')
  if [ -z "$project" ]; then
    echo "No project selected."
    return 1
  fi

  # Select client
  client=$(jira-cli list custom-field-values --name Client --value-only | gum filter --limit 1 --placeholder "Select Client...")
  if [ -z "$client" ]; then
    echo "No client selected."
    return 1
  fi

  # Get GCP logging link from user (bug only)
  if [ "$issue_type" = "bug" ]; then
    logging_link=$(gum input --placeholder "Enter Link to GCP Logging (optional)...")
  fi

  # Select feature
  feature=$(jira-cli list custom-field-values --name Feature --value-only | gum filter --limit 1 --placeholder "Select Feature...")
  if [ -z "$feature" ]; then
    echo "No feature selected."
    return 1
  fi

  # Select board for sprint
  selected_board_id=$(jira-cli list boards --type scrum | gum filter --limit 1 | awk '{print $1}')
  if [ -z "$selected_board_id" ]; then
    echo "No board selected."
    return 1
  fi

  # hard-coded
  # if selected_board_id = 115 then project_team = supply,
  # if selected_board_id = 114 then project_team = transport
  # else prompt user to enter project team label
  if [ "$selected_board_id" -eq 115 ]; then
    project_team="supply"
  elif [ "$selected_board_id" -eq 114 ]; then
    project_team="transport"
  else
    project_team=$(gum input --placeholder "Enter Project Team (e.g., transport, supply)...")
  fi
  if [ -z "$project_team" ]; then
    echo "No project team provided."
    return 1
  fi

  # Select sprint (or backlog)
  local sprint_choice
  sprint_choice=$(jira-cli list sprints --board-id $selected_board_id --state active --state future | gum filter --limit 1 --header "Select a sprint, or press Escape and choose backlog" | awk '{print $1}')
  if [ -z "$sprint_choice" ]; then
    sprint_choice=$(gum choose "backlog" --header "No sprint selected. Add to backlog instead?")
    if [ -z "$sprint_choice" ]; then
      echo "No sprint or backlog selected."
      return 1
    fi
  fi
  if [ "$sprint_choice" != "backlog" ]; then
    selected_sprint="$sprint_choice"
  fi

  # Capitalise the issue type for jira-cli (story -> Story, bug -> Bug, task -> Task)
  local issue_type_cap
  issue_type_cap=$(echo "$issue_type" | awk '{print toupper(substr($0,1,1)) tolower(substr($0,2))}')

  # Build the command
  local cmd="jira-cli create issue -p $project -t $issue_type_cap -s \"$summary\" --custom-field \"Client=$client\" --custom-field \"Project Team=$project_team\" --custom-field \"Feature=$feature\""
  if [ -n "$selected_sprint" ]; then
    cmd="$cmd --sprint \"$selected_sprint\""
  fi

  # Add optional fields
  if [ -n "$description_file" ]; then
    cmd="$cmd --description-file \"$description_file\""
  fi

  if [ -n "$logging_link" ]; then
    cmd="$cmd --custom-field \"Link to GCP Logging=$logging_link\""
  fi

  echo "$cmd"
  eval "$cmd"

  # Clean up the temporary description file if it was created
  if [ -n "$description_file" ] && [ -f "$description_file" ]; then
    rm "$description_file"
  fi
}


# Lists issues from selected sprints on a JIRA board.
# Usage: jira_list_sprint_issues
# Dependencies: jira-cli, gum, awk
# Description: Prompts the user to select a scrum board, then allows selecting
#              one or more active/future sprints from that board. Lists all
#              issues in the selected sprints.
function jira_list_sprint_issues() {
  if [ -z "$(which jira-cli)" ]; then
    echo "jira-cli has not been installed"
    return 1
  fi

  if [ -z "$(which gum)" ]; then
    echo "gum has not been installed"
    return 1
  fi

  if [ -z "$(which awk)" ]; then
    echo "awk has not been installed"
    return 1
  fi

  local selected_board selected_sprints

  # Select board
  selected_board=$(jira-cli list boards --type scrum | gum filter --limit 1 | awk '{print $1}')
  if [ -z "$selected_board" ]; then
    echo "No board selected."
    return 1
  fi

  # Select one or more sprints (active and future), capture ID and name
  selected_sprints=$(jira-cli list sprints --board-id $selected_board --state active --state future | gum filter --no-limit)
  if [ -z "$selected_sprints" ]; then
    echo "No sprints selected."
    return 1
  fi

  # List issues for each selected sprint
  echo "$selected_sprints" | while read -r sprint_line; do
    if [ -n "$sprint_line" ]; then
      local sprint_id sprint_name
      sprint_id=$(echo "$sprint_line" | awk '{print $1}')
      sprint_name=$(echo "$sprint_line" | awk '{$1=""; print $0}' | sed 's/^ *//')
      echo "=== Sprint $sprint_id: $sprint_name ==="
      jira-cli list issues --sprint "$sprint_id" --order-by "RANK ASC"
      echo ""
    fi
  done
}

# Links two JIRA issues together with a selected link type.
# Usage: jira_link_issue <FROM_JIRA_ID> <TO_JIRA_ID>
# Arguments:
#  FROM_JIRA_ID - The JIRA issue identifier to link from (e.g., PROJ-123)
#  TO_JIRA_ID - The JIRA issue identifier to link to (e.g., PROJ-456)
#  Dependencies: jira-cli, gum, awk, xargs
#  Description: Prompts the user to select a link type, then links the
#               specified JIRA issues together using that link type.
#               Example link types: "blocks", "is blocked by", "relates to"
#
function jira_link_issue() {
  if [ -z "$1" ]; then
    echo "Please provide a JIRA ID to link from\nFormat: jira_link_issue <FROM_JIRA_ID> <TO_JIRA_ID>"
    return 1
  fi

  if [ -z "$2" ]; then
    echo "Please provide a JIRA ID to link to\nFormat: jira_link_issue <FROM_JIRA_ID> <TO_JIRA_ID>"
    return 1
  fi

	if [ -z "$(which jira-cli)" ]; then
		echo "jira-cli has not been installed"
		return 1
	fi

  if [ -z "$(which gum)" ]; then
    echo "gum has not been installed"
    return 1
  fi

  if [ -z "$(which awk)" ]; then
    echo "awk has not been installed"
    return 1
  fi

  if [ -z "$(which xargs)" ]; then
    echo "xargs has not been installed"
    return 1
  fi

  local from_jira_id to_jira_id link_type selected_link_type

  selected_link_type=$(jira-cli list link-types | gum filter --limit 1 | awk -F '(' '{print $1}' | xargs)
  if [ -z "$selected_link_type" ]; then
    echo "No link type selected."
    return 1
  fi

  from_jira_id=$1
  to_jira_id=$2

  echo jira-cli update issue --link-type "$selected_link_type" --id "$from_jira_id" --link-issue "$to_jira_id"
  jira-cli update issue --link-type "$selected_link_type" --id "$from_jira_id" --link-issue "$to_jira_id"
}

# Updates the name of an active or future sprint on a JIRA scrum board.
# Usage: jira_update_sprint_name
# Dependencies: jira-cli, gum, awk, jq
# Description: Prompts the user to select a scrum board, then select an
#              active or future sprint from that board, then enter a new
#              name for the sprint. The input is pre-filled with the
#              current sprint name fetched via the jira-cli API.
function jira_update_sprint_name() {
  if [ -z "$(which jira-cli)" ]; then
    echo "jira-cli has not been installed"
    return 1
  fi

  if [ -z "$(which gum)" ]; then
    echo "gum has not been installed"
    return 1
  fi

  if [ -z "$(which awk)" ]; then
    echo "awk has not been installed"
    return 1
  fi

  if [ -z "$(which jq)" ]; then
    echo "jq has not been installed"
    return 1
  fi

  local selected_board selected_sprint new_name

  # Select board
  selected_board=$(jira-cli list boards --type scrum | gum filter --limit 1 --placeholder "Select a board..." | awk '{print $1}')
  if [ -z "$selected_board" ]; then
    echo "No board selected."
    return 1
  fi

  # Select sprint (active and future)
  local selected_sprint_line
  selected_sprint_line=$(jira-cli list sprints --board-id "$selected_board" --state active --state future | gum filter --limit 1 --placeholder "Select a sprint to rename...")
  if [ -z "$selected_sprint_line" ]; then
    echo "No sprint selected."
    return 1
  fi
  selected_sprint=$(awk '{print $1}' <<< "$selected_sprint_line")
  local current_name
  current_name=$(jira-cli get sprint -i "$selected_sprint" --format json | jq -r '.name')

  # Prompt for new sprint name, pre-filled with the current sprint name
  new_name=$(gum input --value "$current_name" --placeholder "Enter new sprint name...")
  if [ -z "$new_name" ]; then
    echo "No sprint name provided."
    return 1
  fi

  jira-cli update sprint --id "$selected_sprint" --name "$new_name"
}


# Starts a future sprint on a JIRA scrum board, making it active.
# Usage: jira_start_sprint
# Dependencies: jira-cli, gum, awk
# Description: Prompts the user to select a scrum board, then select a future
#              sprint from that board, then starts the sprint (changing its
#              state from future to active).
function jira_start_sprint() {
  if [ -z "$(which jira-cli)" ]; then
    echo "jira-cli has not been installed"
    return 1
  fi

  if [ -z "$(which gum)" ]; then
    echo "gum has not been installed"
    return 1
  fi

  if [ -z "$(which awk)" ]; then
    echo "awk has not been installed"
    return 1
  fi

  local selected_board selected_sprint

  # Select board
  selected_board=$(jira-cli list boards --type scrum | gum filter --limit 1 --placeholder "Select a board..." | awk '{print $1}')
  if [ -z "$selected_board" ]; then
    echo "No board selected."
    return 1
  fi

  # Select a future sprint to start
  selected_sprint=$(jira-cli list sprints --board-id "$selected_board" --state future | gum filter --limit 1 --placeholder "Select a future sprint to start..." | awk '{print $1}')
  if [ -z "$selected_sprint" ]; then
    echo "No sprint selected."
    return 1
  fi

  jira-cli start sprint -i "$selected_sprint"
}
